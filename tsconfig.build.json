{
  "compilerOptions": {
    "target": "ES2022",
    "module": "Node16",
    "moduleResolution": "Node16",
    "outDir": "dist",
    "rootDir": "src",
    "lib": ["ES2022"],
    "types": ["@types/node"],
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "declaration": true
  },
  "include": [
    "src/cli.ts",
    "src/handler.ts",
    "src/anilist.ts",
    "src/ical.ts",
    "src/landing.ts"
  ]
}
